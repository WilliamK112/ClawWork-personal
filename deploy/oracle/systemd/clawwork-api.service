[Unit]
Description=ClawWork LiveBench API
After=network.target

[Service]
User=claw
WorkingDirectory=/opt/clawwork
Environment=PYTHONPATH=/opt/clawwork
EnvironmentFile=/opt/clawwork/.env
ExecStart=/opt/clawwork/livebench/.venv/bin/python -m livebench.api.server
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
