[Unit]
Description=ClawWork Paper Tournament Worker
After=network.target clawwork-api.service

[Service]
User=claw
WorkingDirectory=/opt/clawwork
Environment=PYTHONPATH=/opt/clawwork
EnvironmentFile=/opt/clawwork/.env
ExecStart=/opt/clawwork/livebench/.venv/bin/python -m livebench.trading.paper_tournament --interval 15 --cooldown 20
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
